# 国内大模型配置
# LLM_PROVIDER: 模型厂商 (minimax / qwen / doubao / glm / ernie / hunyuan / spark)
LLM_PROVIDER=minimax
LLM_API_KEY=your_api_key_here

# 可选：覆盖默认配置
# LLM_BASE_URL=https://custom-api.example.com/v1
# LLM_MODEL_NAME=custom-model-name

# 各厂商默认模型参考：
# - minimax: MiniMax-Text-01
# - qwen: qwen-plus
# - doubao: doubao-pro-32k
# - glm: glm-4-flash
# - ernie: ernie-4.0-8k-latest
# - hunyuan: hunyuan-pro
# - spark: spark-3.5