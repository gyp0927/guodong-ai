# 国内大模型配置
# LLM_PROVIDER: 模型厂商 (minimax / qwen / doubao / glm / ernie / hunyuan / spark / siliconflow)
LLM_PROVIDER=minimax
LLM_API_KEY=your_api_key_here

# 可选：覆盖默认配置
# LLM_BASE_URL=https://custom-api.example.com/v1
# LLM_MODEL_NAME=custom-model-name

# 各厂商默认模型参考：
# - minimax: MiniMax-Text-01
# - qwen: qwen-plus
# - doubao: doubao-pro-32k
# - glm: glm-4-flash
# - ernie: ernie-4.0-8k-latest
# - hunyuan: hunyuan-pro
# - spark: spark-3.5
# - siliconflow: deepseek-ai/DeepSeek-V3

# ============================
# 自适应记忆系统配置 (可选)
# ============================

# Embedding 配置
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# 如果使用 sentence-transformers (本地，免费):
# EMBEDDING_PROVIDER=sentence-transformers
# LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIMENSION=384
# LOCAL_EMBEDDING_DEVICE=cpu

# 元数据数据库 (SQLite)
# METADATA_DB_URL=sqlite+aiosqlite:///./data/adaptive_memory.db

# 向量数据库集合名
# VECTOR_DB_COLLECTION=agent_memory

# 记忆文件存储路径
# MEMORY_STORE_PATH=./data/memories
